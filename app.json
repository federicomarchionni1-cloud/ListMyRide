{
  "expo": {
    "name": "ListMyRide",
    "slug": "listmyride",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.listmyride.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ListMyRide needs camera access to photograph your vehicle.",
        "NSPhotoLibraryUsageDescription": "ListMyRide needs photo library access to select vehicle photos.",
        "NSPhotoLibraryAddUsageDescription": "ListMyRide needs permission to save photos."
      }
    },
    "android": {
      "package": "com.listmyride.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "ListMyRide needs camera access to photograph your vehicle."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ListMyRide needs photo library access to select vehicle photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ListMyRide needs access to your photos.",
          "savePhotosPermission": "ListMyRide needs permission to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {}
  }
}
